# Configuration PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fdr_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL de connexion DB complète pour psycopg
DATABASE_URL=postgresql://postgres:postgres@db:5432/fdr_db

# Configuration Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# APP configuration
SECRET_KEY=super-secret-key-to-change-in-prod

# Keycloak OIDC
