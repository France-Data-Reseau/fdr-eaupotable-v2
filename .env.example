# Configuration PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fdr_db
POSTGRES_READONLY_USER=fdr_readonly
POSTGRES_READONLY_PASSWORD=fdr_readonly_change_me
POSTGRES_READONLY_DB=${POSTGRES_DB}
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_TLS_CN=db
POSTGRES_TLS_DAYS=3650

# URL de connexion DB complète pour psycopg
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?sslmode=require

# Configuration Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# APP configuration
FDR_APP_TAG=1.0.0

# OIDC
OIDC_ISSUER_URL=https://id.francedatareseau.fr/auth/
OIDC_CLIENT_ID=etl-eaupotable
OIDC_AUDIENCE=fnccr
OIDC_BASE_URI=http://localhost:8000
OIDC_CACHE_TTL=3600