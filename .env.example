# Configuration PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=fdr_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# URL de connexion DB complète pour psycopg
DATABASE_URL=postgresql://postgres:postgres@db:5432/fdr_db

# Configuration Redis / Celery
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=${REDIS_URL}
CELERY_RESULT_BACKEND=${REDIS_URL}

# APP configuration
FDR_APP_TAG=1.0.0

# OIDC
OIDC_ISSUER_URL=https://id.francedatareseau.fr/auth/
OIDC_CLIENT_ID=etl-eaupotable
OIDC_AUDIENCE=fnccr
OIDC_BASE_URI=http://localhost:8000
OIDC_CACHE_TTL=3600
