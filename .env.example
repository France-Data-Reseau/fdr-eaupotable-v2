KEYCLOAK_ISSUER=http://localhost:8080
KEYCLOAK_REALM=fdr
KEYCLOAK_CLIENT_ID=fdr-etl
KEYCLOAK_SUPERSET_CLIENT_ID=fdr-superset
KEYCLOAK_SUPERSET_SECRET=superset-secret-change-in-prod
KEYCLOAK_SUPERSET_INTERNAL_URL=http://kc-host:8080

